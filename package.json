{
  "name": "shopnest-ecommerce",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "Rahul Bk",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "install-all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "dev:server": "cd backend && npm install && npm start",
    "dev:client": "cd frontend && npm install && npm start",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"" ,
    "build" : "cd frontend && npm run build",
    "start:backend": "npm --prefix backend run dev",
    "start:frontend": "npm --prefix frontend run dev",
    "seed" : "npm --prefix backend run seed"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
